import { ThemeTokens } from "theme/tokens.slint";
import { TitlebarTooltip } from "components/titlebar-tooltip.slint";
import { WindowResizeGrips } from "components/window-resize-grips.slint";
import { RightPanel } from "shell/right-panel.slint";
import { Sidebar, SidebarNavItem } from "shell/sidebar.slint";
import { TabBar } from "shell/tabbar.slint";
import { Titlebar } from "shell/titlebar.slint";
import { WelcomeView } from "welcome/welcome-view.slint";

export component AppWindow inherits Window {
    in-out property <bool> dark-mode <=> ThemeTokens.dark-mode;
    in-out property <bool> show-right-panel: false;
    in-out property <bool> show-global-menu: false;
    in-out property <bool> is-window-maximized: false;
    in-out property <bool> use-flat-window-chrome: false;
    in-out property <bool> is-window-active: true;
    in-out property <bool> is-window-always-on-top: false;
    in-out property <bool> show-assets-sidebar: true;
    in-out property <bool> effective-show-assets-sidebar: true;
    in-out property <bool> effective-show-right-panel: false;
    in-out property <string> active-sidebar-destination: "console";
    in-out property <[SidebarNavItem]> sidebar-items: [];
    in-out property <length> shell-body-height-cache: 852px;
    out property <length> layout-titlebar-content-width: titlebar.layout-content-width;
    out property <length> layout-titlebar-nav-zone-width: titlebar.layout-nav-zone-width;
    out property <length> layout-titlebar-window-controls-width: titlebar.layout-window-controls-width;
    out property <length> layout-titlebar-width: titlebar.width;
    out property <length> layout-titlebar-height: titlebar.height;
    out property <length> layout-titlebar-radius: titlebar.layout-radius;
    out property <length> layout-titlebar-maximize-button-x: titlebar.layout-maximize-button-x;
    out property <length> layout-titlebar-maximize-button-y: titlebar.layout-maximize-button-y;
    out property <length> layout-titlebar-maximize-button-width: titlebar.layout-maximize-button-width;
    out property <length> layout-titlebar-maximize-button-height: titlebar.layout-maximize-button-height;
    out property <length> layout-shell-body-height: shell-frame.height - titlebar.height;
    out property <length> layout-shell-body-actual-height: body-host.height;
    out property <length> layout-shell-frame-radius: shell-frame.border-radius;
    out property <length> layout-resize-border-width: root.resize-border-width;
    out property <length> layout-main-workspace-width: main-workspace.width;
    out property <length> layout-right-panel-width: right-panel.width;
    out property <length> layout-activity-bar-width: sidebar.activity-bar-width;
    out property <length> layout-assets-sidebar-width: sidebar.assets-sidebar-width;

    callback drag-requested();
    callback drag-resize-requested(string);
    callback drag-double-clicked();
    callback minimize-requested();
    callback maximize-toggle-requested();
    callback close-requested();
    callback toggle-right-panel-requested();
    callback toggle-global-menu-requested();
    callback close-global-menu-requested();
    callback toggle-theme-mode-requested();
    callback toggle-window-always-on-top-requested();
    callback toggle-assets-sidebar-requested();
    callback sidebar-destination-selected(string);
    callback shell-layout-invalidated(length, length);

    title: "Mica Term";
    no-frame: true;
    resize-border-width: 6px;
    always-on-top: root.is-window-always-on-top;
    background: transparent;
    preferred-width: 1440px;
    preferred-height: 900px;
    min-width: 688px;
    min-height: 640px;

    function sync-shell-body-height() {
        root.shell-body-height-cache = max(0px, root.height - titlebar.height);
    }

    changed width => {
        root.sync-shell-body-height();
        root.shell-layout-invalidated(self.width, self.height);
    }

    changed height => {
        root.sync-shell-body-height();
        root.shell-layout-invalidated(self.width, self.height);
    }

    shell-frame := Rectangle {
        width: root.width;
        height: root.height;
        border-radius: root.use-flat-window-chrome ? 0px : 14px;
        border-width: 1px;
        border-color: ThemeTokens.shell-stroke;
        background: ThemeTokens.shell-surface;

        content-column := Rectangle {
            width: parent.width;
            height: parent.height;
            background: transparent;

            titlebar := Titlebar {
                x: 0px;
                y: 0px;
                width: parent.width;
                dark-mode: root.dark-mode;
                show-right-panel: root.show-right-panel;
                show-global-menu: root.show-global-menu;
                is-window-maximized: root.is-window-maximized;
                use-flat-window-chrome: root.use-flat-window-chrome;
                is-window-active: root.is-window-active;
                is-window-always-on-top: root.is-window-always-on-top;

                drag-requested => {
                    root.drag-requested();
                }

                drag-double-clicked => {
                    root.drag-double-clicked();
                }

                minimize-requested => {
                    root.minimize-requested();
                }

                maximize-toggle-requested => {
                    root.maximize-toggle-requested();
                }

                close-requested => {
                    root.close-requested();
                }

                toggle-right-panel-requested => {
                    root.toggle-right-panel-requested();
                }

                toggle-global-menu-requested => {
                    root.toggle-global-menu-requested();
                }

                close-global-menu-requested => {
                    root.close-global-menu-requested();
                }

                toggle-theme-mode-requested => {
                    root.toggle-theme-mode-requested();
                }

                toggle-window-always-on-top-requested => {
                    root.toggle-window-always-on-top-requested();
                }
            }

            body-host := Rectangle {
                x: 0px;
                y: titlebar.height;
                width: parent.width;
                height: max(0px, parent.height - titlebar.height);
                background: transparent;

                shell-body := HorizontalLayout {
                    width: parent.width;
                    height: parent.height;
                    spacing: 0px;

                    sidebar := Sidebar {
                        items: root.sidebar-items;
                        show-assets-sidebar: root.effective-show-assets-sidebar;
                        active-sidebar-destination: root.active-sidebar-destination;

                        toggle-assets-sidebar-requested => {
                            root.toggle-assets-sidebar-requested();
                        }

                        destination-selected(id) => {
                            root.sidebar-destination-selected(id);
                        }
                    }

                    main-workspace := Rectangle {
                        horizontal-stretch: 1;
                        background: ThemeTokens.terminal-surface;

                        VerticalLayout {
                            spacing: 0px;

                            TabBar {}

                            content-host := Rectangle {
                                vertical-stretch: 1;
                                background: transparent;

                                WelcomeView {}
                            }
                        }
                    }

                    right-panel := RightPanel {
                        expanded: root.effective-show-right-panel;
                    }
                }
            }
        }
    }

    resize-grips := WindowResizeGrips {
        width: root.width;
        height: root.height;

        resize-requested(direction) => {
            root.drag-resize-requested(direction);
        }
    }

    tooltip-overlay := TitlebarTooltip {
        text: titlebar.tooltip-text;
        anchor-x: titlebar.tooltip-anchor-x;
        anchor-y: titlebar.tooltip-anchor-y;
        tooltip-visible: titlebar.tooltip-visible;
        host-width: root.width;
    }

    sidebar-tooltip-overlay := TitlebarTooltip {
        text: sidebar.tooltip-text;
        anchor-x: sidebar.tooltip-anchor-x;
        anchor-y: sidebar.tooltip-anchor-y;
        anchor-width: sidebar.tooltip-anchor-width;
        tooltip-visible: sidebar.tooltip-visible;
        host-width: root.width;
        host-height: root.height;
        place-right: true;
    }
}
