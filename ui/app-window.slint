import { ThemeTokens } from "theme/tokens.slint";
import { RightPanel } from "shell/right-panel.slint";
import { Sidebar } from "shell/sidebar.slint";
import { TabBar } from "shell/tabbar.slint";
import { Titlebar } from "shell/titlebar.slint";
import { WelcomeView } from "welcome/welcome-view.slint";

export component AppWindow inherits Window {
    in property <bool> dark-mode: true;
    in-out property <bool> show-right-panel: false;
    in-out property <bool> show-global-menu: false;
    in-out property <bool> is-window-maximized: false;
    in-out property <bool> is-window-active: true;

    callback drag-requested();
    callback drag-double-clicked();
    callback minimize-requested();
    callback maximize-toggle-requested();
    callback close-requested();
    callback toggle-right-panel-requested();
    callback toggle-global-menu-requested();
    callback close-global-menu-requested();

    title: "Mica Term";
    no-frame: true;
    background: transparent;
    preferred-width: 1440px;
    preferred-height: 900px;

    Rectangle {
        border-radius: 14px;
        border-width: 1px;
        border-color: ThemeTokens.shell-stroke;
        background: ThemeTokens.shell-surface;

        VerticalLayout {
            spacing: 0px;

            Titlebar {
                show-right-panel: root.show-right-panel;
                show-global-menu: root.show-global-menu;
                is-window-maximized: root.is-window-maximized;
                is-window-active: root.is-window-active;

                drag-requested => {
                    root.drag-requested();
                }

                drag-double-clicked => {
                    root.drag-double-clicked();
                }

                minimize-requested => {
                    root.minimize-requested();
                }

                maximize-toggle-requested => {
                    root.maximize-toggle-requested();
                }

                close-requested => {
                    root.close-requested();
                }

                toggle-right-panel-requested => {
                    root.toggle-right-panel-requested();
                }

                toggle-global-menu-requested => {
                    root.toggle-global-menu-requested();
                }

                close-global-menu-requested => {
                    root.close-global-menu-requested();
                }
            }

            HorizontalLayout {
                spacing: 0px;

                Sidebar {}

                Rectangle {
                    background: ThemeTokens.terminal-surface;

                    VerticalLayout {
                        spacing: 0px;

                        TabBar {}

                        Rectangle {
                            background: transparent;

                            WelcomeView {}
                        }
                    }
                }

                RightPanel {
                    expanded: root.show-right-panel;
                }
            }
        }
    }
}
