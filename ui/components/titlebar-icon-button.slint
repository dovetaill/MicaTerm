import { ThemeTokens } from "../theme/tokens.slint";

export component TitlebarIconButton inherits Rectangle {
    in property <image> icon-source;
    in property <image> active-icon-source;
    in property <bool> active: false;
    in property <string> tooltip-text;
    in property <string> tooltip-source-id;
    callback clicked;
    callback tooltip-open-requested(string, string, length, length);
    callback tooltip-close-requested(string);

    private property <image> displayed-icon: root.active
        && root.active-icon-source.width > 0
        && root.active-icon-source.height > 0
        ? root.active-icon-source
        : root.icon-source;
    out property <bool> has-hover: touch.has-hover;

    width: 36px;
    height: 36px;
    border-radius: 8px;
    border-width: root.active ? 1px : 0px;
    border-color: ThemeTokens.shell-stroke;
    background: touch.pressed
        ? ThemeTokens.panel-tint
        : (touch.has-hover || root.active)
            ? ThemeTokens.shell-surface
            : transparent;

    if (root.displayed-icon.width > 0 && root.displayed-icon.height > 0) : Image {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: 20px;
        height: 20px;
        source <=> root.displayed-icon;
        image-fit: contain;
        colorize: ThemeTokens.text-primary;
    }

    changed has-hover => {
        if self.has-hover && root.tooltip-text != "" {
            root.tooltip-open-requested(
                root.tooltip-source-id,
                root.tooltip-text,
                self.absolute-position.x + self.width / 2,
                self.absolute-position.y + self.height + 8px,
            );
        } else {
            root.tooltip-close-requested(root.tooltip-source-id);
        }
    }

    touch := TouchArea {
        clicked => {
            root.tooltip-close-requested(root.tooltip-source-id);
            root.clicked();
        }
    }
}
