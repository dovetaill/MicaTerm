import { ThemeTokens } from "../theme/tokens.slint";

export component TitlebarTooltip inherits Rectangle {
    in property <string> text;
    in property <length> anchor-x: 0px;
    in property <length> anchor-y: 0px;
    in property <bool> tooltip-visible: false;
    in property <length> host-width: 0px;

    x: max(0px, min(root.anchor-x - self.width / 2, max(0px, root.host-width - self.width)));
    y: root.anchor-y;
    width: max(96px, tooltip-label.preferred-width + 20px);
    height: max(28px, tooltip-label.preferred-height + 10px);
    visible: root.tooltip-visible;
    z: 100;

    background-layer := Rectangle {
        width: parent.width;
        height: parent.height;
        border-radius: 8px;
        border-width: 1px;
        border-color: ThemeTokens.shell-stroke;
        background: ThemeTokens.panel-tint;

        tooltip-label := Text {
            x: 10px;
            width: parent.width - 20px;
            height: parent.height;
            text: root.text;
            color: ThemeTokens.text-primary;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }
}
