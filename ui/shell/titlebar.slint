import { ThemeTokens } from "../theme/tokens.slint";
import { TitlebarIconButton } from "../components/titlebar-icon-button.slint";
import { TitlebarMenu } from "../components/titlebar-menu.slint";
import { TitlebarTooltip } from "../components/titlebar-tooltip.slint";
import { WindowControlButton } from "../components/window-control-button.slint";

export component Titlebar inherits Rectangle {
    in property <bool> dark-mode: true;
    in property <bool> show-right-panel: false;
    in property <bool> show-global-menu: false;
    in property <bool> is-window-maximized: false;
    in property <bool> is-window-active: true;
    in property <bool> is-window-always-on-top: false;
    in property <bool> tooltip-visible: false;

    private property <image> navigation-icon: @image-url("../../assets/icons/fluent/navigation-24-regular.svg");
    private property <image> header-logotype: @image-url("../../assets/icons/mica-term-header-logotype.svg");
    private property <image> dark-theme-icon: @image-url("../../assets/icons/fluent/dark-theme-20-regular.svg");
    private property <image> weather-sunny-icon: @image-url("../../assets/icons/fluent/weather-sunny-20-regular.svg");
    private property <image> panel-right-icon-regular: @image-url("../../assets/icons/fluent/panel-right-20-regular.svg");
    private property <image> panel-right-icon-filled: @image-url("../../assets/icons/fluent/panel-right-20-filled.svg");
    private property <image> pin-icon: @image-url("../../assets/icons/fluent/pin-20-regular.svg");
    private property <image> pin-off-icon: @image-url("../../assets/icons/fluent/pin-off-20-regular.svg");
    private property <image> minimize-icon: @image-url("../../assets/icons/fluent/subtract-20-regular.svg");
    private property <image> maximize-icon: @image-url("../../assets/icons/fluent/maximize-20-regular.svg");
    private property <image> restore-icon: @image-url("../../assets/icons/fluent/restore-20-regular.svg");
    private property <image> close-icon: @image-url("../../assets/icons/fluent/dismiss-20-regular.svg");
    private property <string> tooltip-text-value: "";
    private property <bool> tooltip-visible-value: false;
    private property <string> tooltip-source-id-value: "";
    private property <length> tooltip-anchor-x-value: 0px;
    private property <length> tooltip-anchor-y-value: 0px;

    callback drag-requested;
    callback drag-double-clicked;
    callback toggle-theme-mode-requested;
    callback toggle-right-panel-requested;
    callback toggle-global-menu-requested;
    callback close-global-menu-requested;
    callback toggle-window-always-on-top-requested;
    callback minimize-requested;
    callback maximize-toggle-requested;
    callback close-requested;
    callback tooltip-debug-event-requested(string, string, string, length, length);

    height: 48px;
    background: ThemeTokens.command-tint;
    border-radius: 12px;
    border-width: 1px;
    border-color: ThemeTokens.shell-stroke;

    changed show-global-menu => {
        close-tooltip("");
        if root.show-global-menu {
            global-menu.show();
        } else {
            global-menu.close();
        }
    }

    function schedule-tooltip(source-id: string, text: string, anchor-x: length, anchor-y: length) {
        root.tooltip-source-id-value = source-id;
        root.tooltip-text-value = text;
        root.tooltip-anchor-x-value = anchor-x - self.absolute-position.x;
        root.tooltip-anchor-y-value = anchor-y - self.absolute-position.y;
        root.tooltip-debug-event-requested(
            source-id,
            "schedule-tooltip",
            text,
            root.tooltip-anchor-x-value,
            root.tooltip-anchor-y-value,
        );
        root.tooltip-visible-value = false;
        tooltip-delay.restart();
    }

    function close-tooltip(source-id: string) {
        if root.tooltip-source-id-value == source-id || source-id == "" {
            root.tooltip-debug-event-requested(
                root.tooltip-source-id-value,
                "close-tooltip",
                root.tooltip-text-value,
                root.tooltip-anchor-x-value,
                root.tooltip-anchor-y-value,
            );
            root.tooltip-visible-value = false;
            root.tooltip-text-value = "";
            root.tooltip-source-id-value = "";
            tooltip-delay.stop();
        }
    }

    content := HorizontalLayout {
        x: 6px;
        y: 6px;
        width: parent.width - 12px;
        height: 36px;
        spacing: 0px;

        nav-zone := Rectangle {
            width: 44px;
            height: parent.height;
            background: transparent;
            opacity: root.is-window-active ? 1 : 0.72;

            nav-button := TitlebarIconButton {
                x: 4px;
                y: 0px;
                icon-source: root.navigation-icon;
                active: root.show-global-menu;
                tooltip-text: "Open menu";
                tooltip-source-id: "nav-button";

                clicked => {
                    root.toggle-global-menu-requested();
                }

                tooltip-open-requested(source-id, text, anchor-x, anchor-y) => {
                    root.schedule-tooltip(source-id, text, anchor-x, anchor-y);
                }

                tooltip-close-requested(source-id) => {
                    root.close-tooltip(source-id);
                }
            }
        }

        brand-zone := Rectangle {
            width: 188px;
            height: parent.height;
            background: transparent;
            opacity: root.is-window-active ? 1 : 0.84;

            brand-logotype := Image {
                x: 0px;
                y: 6px;
                width: 170px;
                height: 24px;
                source: root.header-logotype;
                image-fit: contain;
                colorize: ThemeTokens.text-primary;
            }
        }

        drag-zone := Rectangle {
            background: transparent;
            border-radius: 8px;
            opacity: root.is-window-active ? 1 : 0.72;

            drag-touch := TouchArea {
                width: parent.width;
                height: parent.height;

                moved => {
                    if self.pressed {
                        root.drag-requested();
                    }
                }

                double-clicked => {
                    root.drag-double-clicked();
                }
            }
        }

        utility-zone := Rectangle {
            width: 136px;
            height: parent.height;
            background: transparent;
            opacity: root.is-window-active ? 1 : 0.72;

            theme-button := TitlebarIconButton {
                x: 0px;
                y: 0px;
                icon-source: root.dark-mode ? root.dark-theme-icon : root.weather-sunny-icon;
                tooltip-text: root.dark-mode ? "Switch to light mode" : "Switch to dark mode";
                tooltip-source-id: "theme-button";

                clicked => {
                    root.toggle-theme-mode-requested();
                }

                tooltip-open-requested(source-id, text, anchor-x, anchor-y) => {
                    root.schedule-tooltip(source-id, text, anchor-x, anchor-y);
                }

                tooltip-close-requested(source-id) => {
                    root.close-tooltip(source-id);
                }
            }

            panel-toggle-button := TitlebarIconButton {
                x: 40px;
                y: 0px;
                icon-source: root.panel-right-icon-regular;
                active-icon-source: root.panel-right-icon-filled;
                active: root.show-right-panel;
                tooltip-text: "Toggle right panel";
                tooltip-source-id: "panel-toggle-button";

                clicked => {
                    root.toggle-right-panel-requested();
                }

                tooltip-open-requested(source-id, text, anchor-x, anchor-y) => {
                    root.schedule-tooltip(source-id, text, anchor-x, anchor-y);
                }

                tooltip-close-requested(source-id) => {
                    root.close-tooltip(source-id);
                }
            }

            divider-line := Rectangle {
                x: 84px;
                y: 8px;
                width: 1px;
                height: 20px;
                border-radius: 1px;
                background: ThemeTokens.shell-stroke;
            }

            pin-button := TitlebarIconButton {
                x: 100px;
                y: 0px;
                icon-source: root.is-window-always-on-top ? root.pin-icon : root.pin-off-icon;
                active: root.is-window-always-on-top;
                tooltip-text: root.is-window-always-on-top ? "Unpin window from top" : "Pin window on top";
                tooltip-source-id: "pin-button";

                clicked => {
                    root.toggle-window-always-on-top-requested();
                }

                tooltip-open-requested(source-id, text, anchor-x, anchor-y) => {
                    root.schedule-tooltip(source-id, text, anchor-x, anchor-y);
                }

                tooltip-close-requested(source-id) => {
                    root.close-tooltip(source-id);
                }
            }
        }

        window-controls := Rectangle {
            width: 138px;
            height: parent.height;
            background: transparent;
            opacity: root.is-window-active ? 1 : 0.72;

            minimize-button := WindowControlButton {
                x: 0px;
                y: 0px;
                icon-source: root.minimize-icon;
                tooltip-text: "Minimize window";
                tooltip-source-id: "minimize-button";

                clicked => {
                    root.minimize-requested();
                }

                tooltip-open-requested(source-id, text, anchor-x, anchor-y) => {
                    root.schedule-tooltip(source-id, text, anchor-x, anchor-y);
                }

                tooltip-close-requested(source-id) => {
                    root.close-tooltip(source-id);
                }
            }

            maximize-button := WindowControlButton {
                x: 46px;
                y: 0px;
                icon-source: root.is-window-maximized ? root.restore-icon : root.maximize-icon;
                tooltip-text: root.is-window-maximized ? "Restore window" : "Maximize window";
                tooltip-source-id: "maximize-button";

                clicked => {
                    root.maximize-toggle-requested();
                }

                tooltip-open-requested(source-id, text, anchor-x, anchor-y) => {
                    root.schedule-tooltip(source-id, text, anchor-x, anchor-y);
                }

                tooltip-close-requested(source-id) => {
                    root.close-tooltip(source-id);
                }
            }

            close-button := WindowControlButton {
                x: 92px;
                y: 0px;
                icon-source: root.close-icon;
                danger: true;
                tooltip-text: "Close window";
                tooltip-source-id: "close-button";

                clicked => {
                    root.close-requested();
                }

                tooltip-open-requested(source-id, text, anchor-x, anchor-y) => {
                    root.schedule-tooltip(source-id, text, anchor-x, anchor-y);
                }

                tooltip-close-requested(source-id) => {
                    root.close-tooltip(source-id);
                }
            }
        }
    }

    tooltip-delay := Timer {
        interval: 280ms;
        running: false;

        triggered => {
            self.running = false;

            if root.tooltip-text-value != "" {
                root.tooltip-visible-value = true;
                root.tooltip-debug-event-requested(
                    root.tooltip-source-id-value,
                    "show-tooltip",
                    root.tooltip-text-value,
                    root.tooltip-anchor-x-value,
                    root.tooltip-anchor-y-value,
                );
            }
        }
    }

    global-menu := TitlebarMenu {
        x: nav-button.absolute-position.x;
        y: nav-button.absolute-position.y + nav-button.height + 6px;

        close-requested => {
            root.close-global-menu-requested();
        }

        settings-selected => {
            root.close-global-menu-requested();
        }

        appearance-selected => {
            root.close-global-menu-requested();
        }
    }

    tooltip-overlay := TitlebarTooltip {
        text: root.tooltip-text-value;
        anchor-x: root.tooltip-anchor-x-value;
        anchor-y: root.tooltip-anchor-y-value;
        tooltip-visible: root.tooltip-visible-value;
        host-width: root.width;
    }
}
