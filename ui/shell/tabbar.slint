export component TabBar inherits Rectangle {
    height: 38px;
    background: transparent;
    border-width: 1px;
    border-color: ThemeTokens.shell-stroke;

    ActiveTab {
        x: 12px;
        y: 5px;
        width: 140px;
        height: 28px;
    }
}
